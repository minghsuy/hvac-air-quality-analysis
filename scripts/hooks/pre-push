#!/usr/bin/env bash
# scripts/hooks/pre-push — tracked in the repo, install via scripts/install-hooks.sh
#
# Runs before `git push`. Blocks pushes to main/master, runs ruff check + format,
# scans for device identifiers and secret-shaped strings, and (if the HTML report
# or its generating scripts changed) runs the Playwright screenshot check.

set -euo pipefail

branch=$(git branch --show-current)

# 1. Block direct pushes to main/master
if [[ "$branch" == "main" || "$branch" == "master" ]]; then
    echo "BLOCKED: direct push to $branch is not allowed."
    echo "Create a feature branch and PR instead."
    exit 1
fi

remote="${1:-origin}"
upstream="$remote/$branch"
# On a pushed branch, compare against the upstream. On the FIRST push of a new
# branch (no upstream yet) we'd otherwise fall back to "range=HEAD" which means
# `git diff HEAD` — that's working-tree-vs-HEAD, which is empty on a clean tree
# at push time. The scan would silently match nothing. Use the merge-base with
# origin/main (or master, or HEAD^) so the scan actually sees new commits.
if git rev-parse --verify --quiet "$upstream" >/dev/null 2>&1; then
    range="$upstream..HEAD"
else
    base=$(git merge-base HEAD "$remote/main" 2>/dev/null \
        || git merge-base HEAD "$remote/master" 2>/dev/null \
        || git rev-parse HEAD^)
    range="$base..HEAD"
fi
changed_files=$(git diff --name-only "$range" 2>/dev/null || true)

# 2. ruff check (lint)
echo "-> ruff check"
uv run --quiet ruff check . \
    || { echo "FAIL: run 'uv run ruff check . --fix' then re-stage and re-push"; exit 1; }

# 3. ruff format --check (formatting)
echo "-> ruff format --check"
uv run --quiet ruff format --check . \
    || { echo "FAIL: run 'uv run ruff format .' then re-stage and re-push"; exit 1; }

# 4. Device-identifier / secret scan
#    Broader than the Claude-Code built-in: covers sensor ID strings with
#    various vendor prefixes, not just d8:3b:da.
echo "-> secret / device-id scan"
patterns=(
    '192\.168\.[0-9]'                                      # local IPs
    'd8:3b:da'                                             # Airthings MAC prefix
    'GOOGLE_SPREADSHEET_ID[[:space:]]*=[[:space:]]*["'\''][A-Za-z0-9_-]{20}'
    '(airthings|airgradient|tempstick|ecobee|nest)_[A-Fa-f0-9]{4,}'
)
for pat in "${patterns[@]}"; do
    if git diff "$range" -U0 --no-color 2>/dev/null | grep -Ei "$pat" >/dev/null; then
        echo "FAIL: pattern /$pat/ matched in pushed diff:"
        git diff "$range" -U0 --no-color | grep -Ei "$pat" | head -3
        exit 1
    fi
done

# 5. uv.lock sanity check: revision must not regress
#    (I hit this once when an older uv wrote revision=2 over a revision=3 lock)
echo "-> uv.lock revision check"
lock_rev=$(awk -F' = ' '/^revision / {print $2; exit}' uv.lock 2>/dev/null || echo 0)
if [[ "${lock_rev:-0}" -lt 3 ]]; then
    echo "FAIL: uv.lock revision=$lock_rev is below 3."
    echo "      Your uv may be out of date. Run: uv self update && uv lock"
    exit 1
fi

# 6. pytest (conditional: only if .py files outside docs/ changed)
#    Docs-only pushes skip the ~2s overhead; real code changes run the suite.
py_changed=$(echo "$changed_files" | grep -E '\.py$' | grep -v '^docs/' || true)
if [[ -n "$py_changed" ]]; then
    echo "-> pytest (Python changes outside docs/)"
    uv run --quiet pytest -q \
        || { echo "FAIL: pytest failures — fix or re-evaluate before re-pushing"; exit 1; }
fi

# 7. Visual render check (conditional: only if HTML or its generators changed)
if echo "$changed_files" | grep -qE 'docs/reports/findings\.html|scripts/analysis/(verify|screenshot)_findings'; then
    echo "-> screenshot verify (HTML report or its generators changed)"
    uv run --quiet python scripts/analysis/screenshot_report.py
fi

echo "OK: pre-push checks passed"
